# ─── flightdad backend — environment variables ────────────────────────────────
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# .env.local is gitignored and will not be committed.
# ──────────────────────────────────────────────────────────────────────────────

# Runtime environment: development | test | production
NODE_ENV=development

# HTTP port the backend server listens on
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
#
# DB_TYPE=memory   → in-process document store (local dev & test)
# DB_TYPE=dynamodb → AWS DynamoDB (production)
DB_TYPE=memory

# ─── DynamoDB (production only — ignored when DB_TYPE=memory) ─────────────────
# AWS_REGION=us-east-1
# DYNAMODB_TABLE_PREFIX=flightdad

# ─── Background worker ────────────────────────────────────────────────────────
#
# How often (in milliseconds) the itinerary worker polls for due records when
# running locally.  In production this is controlled by the EventBridge rule.
# WORKER_POLL_INTERVAL_MS=60000

# ─── AviationStack (flight data provider) ────────────────────────────────────
#
# API key from https://aviationstack.com (free plan: 100 live calls/month).
# Required for GET /flights/:flightNumber to return real-time status data.
# See docs/flight-tracker-api.md for setup instructions.
AVIATIONSTACK_API_KEY=
