# flightdad mobile app — environment variables
#
# Copy this file to .env.local and adjust values for your setup.
# Expo reads variables prefixed with EXPO_PUBLIC_ and makes them available
# at runtime via process.env.EXPO_PUBLIC_*.
#
# .env.local is git-ignored; never commit real values.

# Base URL of the flightdad backend.
#
# ── iOS Simulator ──────────────────────────────────────────────────────────
# The simulator shares the Mac's network, so localhost works as-is.
EXPO_PUBLIC_API_URL=http://localhost:3000
#
# ── Physical iPhone ────────────────────────────────────────────────────────
# The phone is on your Wi-Fi; use your Mac's LAN IP instead of localhost.
# Find it with: ipconfig getifaddr en0   (macOS)
# EXPO_PUBLIC_API_URL=http://192.168.1.x:3000
